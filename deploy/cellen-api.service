[Unit]
Description=Cellen API
After=network.target postgresql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/cellen
EnvironmentFile=/var/www/cellen/.env
ExecStart=/var/www/cellen/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8001 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
