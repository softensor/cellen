DATABASE_URL=postgresql+asyncpg://cellen:password@localhost:5432/cellen
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
MEDIA_DIR=/app/media
PLATFORM_ADMIN_EMAIL=admin@cellen.app
PLATFORM_ADMIN_PASSWORD=change-this-on-first-boot
# Gmail SMTP: enable 2-Step Verification, then create a Gmail App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=contact@cellen.ao
SMTP_PASSWORD=your-16-character-gmail-app-password
SMTP_FROM_EMAIL=contact@cellen.ao
CONTACT_RECIPIENT_EMAIL=admin@cellen.ao
